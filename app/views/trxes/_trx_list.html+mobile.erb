<!-- Transactions list (mobile) -->
<div class="flex flex-col flex-grow overflow-hidden">
  <% if trxes.any? %>
    <!-- Scrollable data rows - grouped by date -->
    <div class="overflow-y-auto flex-grow">
      <div>
        <% trxes.group_by(&:date).each do |date, date_trxes| %>
          <div>
            <!-- Date header -->
            <div class="bg-gray-100 px-2 py-1 text-sm font-medium text-gray-600">
              <%= date.strftime("%B %-d, %Y") %>
            </div>

            <!-- Transactions for this date -->
            <% date_trxes.each do |trx| %>
              <div class="bg-white shadow-sm p-1 hover:bg-gray-50 border-b border-gray-200">
                <div class="flex justify-between items-start">
                  <div class="flex-grow">
                    <%= link_to edit_trx_path(trx), class: "block" do %>
                      <div class="flex justify-between items-start mb-2">
                        <div class="text-blue-600 font-medium"><%= trx.vendor.name %></div>
                        <div class="<%= trx.amount < 0 ? 'text-red-600' : 'text-green-600' %> font-medium">
                          <%= number_to_currency(trx.amount / 100.0) %>
                        </div>
                      </div>
                    <% end %>
                    <div class="flex flex-wrap justify-between items-start gap-x-4">
                      <div class="text-sm text-gray-600 flex-grow min-w-[200px]">
                        <% if trx.lines.size > 1 %>
                          <div data-controller="split-toggle" class="flex flex-col">
                            <button data-action="click->split-toggle#toggle" class="flex items-center gap-1 text-gray-500 hover:text-gray-700">
                              <span>Split</span>
                              <svg data-split-toggle-target="icon" class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                              </svg>
                            </button>
                            <div data-split-toggle-target="content" class="mt-2 pt-2 border-t border-gray-100 hidden">
                              <% trx.lines.each do |line| %>
                                <div class="flex justify-between items-center text-sm">
                                  <div class="text-gray-600"><%= line.ledger&.subcategory&.name %></div>
                                  <div class="text-gray-600"><%= number_to_currency(line.amount / 100.0) %></div>
                                </div>
                              <% end %>
                            </div>
                          </div>
                        <% else %>
                          <span><%= trx.lines.first&.ledger&.subcategory&.name %></span>
                        <% end %>
                        <% if trx.memo.present? %>
                          <span class="text-gray-500 ml-2 truncate max-w-[200px]"><%= trx.memo %></span>
                        <% end %>
                      </div>
                      <div class="text-sm text-gray-600"><%= trx.account.name %></div>
                    </div>
                  </div>

                  <div class="mx-2 flex flex-col items-center justify-between h-full">
                    <div data-controller="cleared-toggle"
                         data-cleared-toggle-trx-id-value="<%= trx.id %>"
                         data-cleared-toggle-cleared-value="<%= trx.cleared %>">
                      <button data-action="click->cleared-toggle#toggle" class="focus:outline-none">
                        <div data-cleared-toggle-target="circle"
                             class="w-4 h-4 rounded-full <%= trx.cleared ? 'bg-green-500' : 'bg-gray-300' %> mb-2">
                        </div>
                      </button>
                    </div>
                    <div class="font-bold text-gray-700">
                      <%= 'T' if trx.lines.any? { |line| line.transfer_line.present? } %>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Footer (compact for mobile) -->
    <div class="mt-1 flex justify-between items-center sticky bottom-0 bg-gray-100 px-1.5 py-1 border-t border-gray-200 min-h-0">
      <div class="scale-90 origin-right">
        <%= custom_pagy_nav(pagy) %>
      </div>
    </div>
  <% else %>
    <div class="flex-grow flex items-center justify-center">
      <div class="text-center p-8 bg-white rounded-lg shadow-sm max-w-md">
        <p class="text-gray-600 mb-4">No transactions found.</p>
        <%= link_to new_trx_path, class: "px-4 py-2 bg-blue-500 hover:bg-blue-600 text-white rounded-md inline-block" do %>
          <i class="fas fa-plus mr-2"></i> Create Your First Transaction
        <% end %>
      </div>
    </div>
  <% end %>
</div>
